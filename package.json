{
  "name": "react-native-pagseguro-plugpag",
  "version": "1.0.0-rc.3",
  "description": "Integre facilmente as principais formas de pagamento da PagSeguro em seus aplicativos React Native através deste módulo nativo.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json",
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js"
  },
  "files": [
    "src",
    "lib",
    "android",
    "app.plugin.js",
    "plugin/build",
    "react-native.config.js",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-pagseguro-plugpag-example",
    "clean": "del-cli lib",
    "build:plugin": "tsc --project tsconfig.plugin.json",
    "prepare": "yarn build:plugin && bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest",
    "prepublishOnly": "yarn lint && yarn typecheck && yarn test && yarn bob build && yarn build:plugin",
    "release:rc": "npm publish --tag rc",
    "release:patch": "npm version patch && npm publish --tag latest",
    "release:minor": "npm version minor && npm publish --tag latest",
    "release:major": "npm version major && npm publish --tag latest",
    "release:promote": "npm dist-tag add react-native-pagseguro-plugpag@$(node -p \"require('./package.json').version\") latest"
  },
  "keywords": [
    "react-native",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brunodsazevedo/react-native-pagseguro-plugpag.git"
  },
  "author": "brunodsazevedo <bruno.ds.azevedo@gmail.com> (https://github.com/brunodsazevedo)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/brunodsazevedo/react-native-pagseguro-plugpag/issues"
  },
  "homepage": "https://github.com/brunodsazevedo/react-native-pagseguro-plugpag#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@expo/config-plugins": "^9.0.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.12",
    "@types/react-test-renderer": "^19",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.40.18",
    "react-test-renderer": "19.2.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "PagseguroPlugpagSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.pagseguroplugpag"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "haste": {
      "defaultPlatform": "android"
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin",
    "tools": [
      "eslint",
      "jest"
    ],
    "version": "0.57.2"
  }
}
